# Optional session signing key (a built-in fallback is used if empty)
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Optional custom path for local page data override (development only)
LOCAL_DATA_PATH=

# Admin credentials: edit src/data/admin.json
# Production file storage: edit src/config/storage.json (GitHub repo + token)

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=+1234567890
