# Web App (copy to web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4000
JWT_SECRET=

# Data source: api | local (defaults to local in development, api in production)
DATA_SOURCE=local
DATA_FALLBACK=true
LOCAL_DATA_PATH=

# Admin login in local mode is read from web/src/data/admin.json

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=+1234567890

# API Backend (copy to api/.env)
DATABASE_URL=postgresql://postgres:password@localhost:5432/viora
PORT=4000
JWT_SECRET=
JWT_EXPIRES_IN=24h
CORS_ORIGIN=http://localhost:3000
ADMIN_EMAIL=admin@viora.com
ADMIN_PASSWORD=changeme
