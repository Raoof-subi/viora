# Web App (copy to web/.env.local)
# JWT_SECRET is optional — a built-in secret is derived from admin.json in production
JWT_SECRET=
JWT_EXPIRES_IN=24h
LOCAL_DATA_PATH=

# Admin login credentials are read from web/src/data/admin.json

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=+1234567890
